# =============================================
# DUTCH.IND - ENVIRONMENT VARIABLES
# =============================================
# Salin file ini menjadi .env.local dan isi nilainya

# ----- DATABASE -----
DATABASE_URL="postgresql://username:password@localhost:5432/dutch_ind_db"
# Untuk MySQL gunakan:
# DATABASE_URL="mysql://username:password@localhost:3306/dutch_ind_db"

# ----- NEXTAUTH -----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-nextauth-key-change-this"

# ----- JWT -----
JWT_SECRET="your-jwt-secret-key-minimum-32-characters"
JWT_EXPIRES_IN="7d"

# ----- MIDTRANS PAYMENT -----
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxxxxxxxxxxxxxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxxxxxxxxxxxxxx"
MIDTRANS_IS_PRODUCTION="false"
# Production keys (ganti saat go-live):
# MIDTRANS_SERVER_KEY="Mid-server-xxxxxxxxxxxxxxxxxxxx"
# MIDTRANS_CLIENT_KEY="Mid-client-xxxxxxxxxxxxxxxxxxxx"
# MIDTRANS_IS_PRODUCTION="true"

# ----- STRIPE (opsional) -----
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ----- EMAIL (Nodemailer) -----
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="DUTCH.IND <noreply@dutch.ind>"

# ----- CLOUDINARY (Upload Gambar) -----
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ----- APP SETTINGS -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="DUTCH.IND"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CURRENCY="IDR"
NEXT_PUBLIC_CURRENCY_LOCALE="id-ID"
